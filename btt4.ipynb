      "400\n",
      "n trong [1, 1000]\n",
      "Tổng từ 1 đến n là: 80200\n"
     ]
    }
   ],
   "source": [
    "n = int(input(\"Nhập n (<= 1000):\"))\n",
    "print(n)\n",
    "if 1 <= n <= 1000:\n",
    "    print(\"n trong [1, 1000]\")\n",
    "    tong = 0\n",
    "    for i in range(1, n + 1):\n",
    "        tong += i\n",
    "    print(\"Tổng từ 1 đến n là:\", tong)\n",
    "else:\n",
    "    print(\"n không hợp lệ\")"
   ]
